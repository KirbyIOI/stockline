# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# --- Server ---
PORT=4000
DB_PATH=./data/inventory.db
CLIENT_ORIGIN=http://localhost:5173

# --- Login (first admin account) ---
# Used ONCE, the very first time the app starts with an empty database, to
# create your first admin account. After that, this app has real user
# accounts (Settings -> Team) and these two lines are ignored — change your
# password from inside the app, not by editing this file.
ADMIN_USERNAME=kirby
ADMIN_PASSWORD=8vPx6gdLmMS1ctvA
# Any long random string. Used to sign login sessions. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=Eeg4cxW7AKpKwQWz

# --- AI Assistant (optional) ---
# Leave blank to disable the "Ask Stockline" chat feature entirely — the rest
# of the app works fine without it. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=
# Optional: override the model used by the assistant.
# ANTHROPIC_MODEL=claude-sonnet-5
